server {
    server_name 72.61.125.165 maryamhostel.com www.maryamhostel.com;

    # 1. React Frontend (Serve from root)
    root /var/www/maryamhostel/frontend;
    index index.html;

    location / {
        try_files $uri $uri/ /index.html;
    }

    # 2. Django Static Files (Admin/Jazzmin)
    # We use /django_static/ to avoid clashing with React's /static/ folder
    location /django_static/ {
        alias /var/www/maryamhostel/backend/staticfiles/;
    }

    # 3. Django Media Files
    location /media/ {
        alias /var/www/maryamhostel/backend/media/;
    }

    # 4. Django Admin Panel
    location /admin/ {
       proxy_pass http://127.0.0.1:8001;
       proxy_set_header Host $host;
       proxy_set_header X-Real-IP $remote_addr;
       proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
       proxy_set_header X-Forwarded-Proto $scheme;
    }

    # 5. Django API
    location /api/ {
        proxy_pass http://127.0.0.1:8001;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
    }

    listen 443 ssl; # managed by Certbot
    ssl_certificate /etc/letsencrypt/live/maryamhostel.com/fullchain.pem; # managed by Certbot
    ssl_certificate_key /etc/letsencrypt/live/maryamhostel.com/privkey.pem; # managed by Certbot
    include /etc/letsencrypt/options-ssl-nginx.conf; # managed by Certbot
    ssl_dhparam /etc/letsencrypt/ssl-dhparams.pem; # managed by Certbot
}

server {
    if ($host = www.maryamhostel.com) {
        return 301 https://$host$request_uri;
    } # managed by Certbot

    if ($host = maryamhostel.com) {
        return 301 https://$host$request_uri;
    } # managed by Certbot

    listen 80;
    server_name 72.61.125.165 maryamhostel.com www.maryamhostel.com;
    return 404; # managed by Certbot
}
